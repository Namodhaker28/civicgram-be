PORT=4000
MONGODB_URI=mongodb://localhost:27017/civic-social
JWT_SECRET=your-super-secret-jwt-key-change-in-production
FRONTEND_ORIGIN=http://localhost:3000

# Google Sign-In (Web client ID; must match frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Email verification (Resend: https://resend.com — if unset, verification URL is logged to server console)
RESEND_API_KEY=
MAIL_FROM="namodhaker28@gmail.com"

# Comma-separated admin emails (promoted to role admin on startup and at registration)
ADMIN_EMAILS=namo@gmail.com

# Creator payout: paise per max(0, upvotes − downvotes) per post in monthly settlement (100 = ₹1 per point)
INR_PER_NET_POINT_PAISE=100

# Option A: three values from https://console.cloudinary.com/settings/api
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Option B: single URL (api_secret must be URL-encoded if it has special chars)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Upload folders (set in code): civic-social/posts/videos, civic-social/profiles/avatars, civic-social/posts/images
